  "telephone": "+1-312-218-7677",
  "priceRange": "$",
  "image": "https://www.theflamechicago.com/assets/img/og.jpg",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "1231 N Ashland Ave",
    "addressLocality": "Chicago",
    "addressRegion": "IL",
    "postalCode": "60622",
    "addressCountry": "US"
  },
  "areaServed": { "@type": "City", "name": "Chicago" },
