<body>
<a class="skip" href="#main">Skip to content</a>

<!-- ============ HEADER ============ -->
<header class="site-header" id="siteHeader">
  <a class="brand" href="/" aria-label="The Flame Chicago home"><span class="fl">The&nbsp;Flame</span></a>
  <nav class="nav" id="nav" aria-label="Primary">
    <a class="navlink" href="#experience">Experience</a>
    <a class="navlink" href="#atmosphere">Atmosphere</a>
    <a class="navlink" href="#visit">Visit</a>
  </nav>
